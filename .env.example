# Copy to .env.local and fill in. These values are PUBLIC by design (they ship in
# the client bundle). Security is enforced by Firestore rules + anonymous auth and
# by the restricted Cloudinary upload preset — NOT by hiding these values.

# --- Firebase (Project settings → General → Your apps → SDK config) ---
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# --- Cloudinary ---
# Cloud name: Cloudinary dashboard.
# Upload preset: Settings → Upload → Upload presets → add an UNSIGNED preset.
VITE_CLOUDINARY_CLOUD_NAME=
VITE_CLOUDINARY_UPLOAD_PRESET=
